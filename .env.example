# Minimum cosine similarity score required to match a domain.
# Requests with a best score below this threshold are classified as "unknown".
# Range: 0.0 to 1.0. Default: 0.40
# Raise to require closer matches; lower to be more permissive.
SIMILARITY_THRESHOLD=0.40

# Override the directory where the knowledge base is stored.
# Default: the kb/ folder at the project root.
# Useful if you want to share a KB across multiple installations.
# KB_PATH=/path/to/your/kb
